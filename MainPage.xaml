<Page
    x:Class="RodnikiRadio.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/api/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
        <TextBlock Text="Радио Родники" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        
        <Button Content="ИГРАТЬ" Click="PlayButton_Click" 
                Width="200" Height="60" Background="Green" Foreground="White"/>
        
        <Button Content="СТОП" Click="PauseButton_Click" 
                Width="200" Height="60" Background="DarkRed" Foreground="White"/>

        <TextBlock x:Name="StatusText" Text="Готов к работе" HorizontalAlignment="Center" Margin="0,20,0,0"/>
    </StackPanel>
</Page>
