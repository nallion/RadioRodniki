<Page
    x:Class="RodnikiRadio.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RodnikiRadio"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#1D1D1D" Padding="15">
            <TextBlock Text="FM PLAY Россия" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <ListView x:Name="RadioList" Grid.Row="1" SelectionChanged="RadioList_SelectionChanged" Margin="10">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Border Width="50" Height="50" CornerRadius="5" Margin="0,0,15,0">
                            <Image Source="{Binding LogoUrl}" Stretch="UniformToFill"/>
                        </Border>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="18"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2" Background="#252525" Padding="20">
            <!-- Прокручиваемый блок для полного текста ошибки -->
            <ScrollViewer Height="80" HorizontalScrollMode="Disabled" VerticalScrollMode="Auto" Margin="0,0,0,10">
                <TextBlock x:Name="StatusText"
                           Text="Выберите станцию"
                           Foreground="White"
                           TextWrapping="Wrap"
                           FontSize="13"
                           FontFamily="Consolas"/>
            </ScrollViewer>
            <!-- Таймер воспроизведения -->
            <TextBlock x:Name="TimerText"
                       Text=""
                       Foreground="#AAAAAA"
                       FontSize="13"
                       FontFamily="Consolas"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="&#x23EE;" Click="PrevButton_Click" Width="70" Margin="5" FontSize="18"/>
                <Button Content="Играть" Click="PlayButton_Click" Width="100" Margin="5"/>
                <Button Content="Пауза" Click="PauseButton_Click" Width="100" Margin="5"/>
                <Button Content="&#x23ED;" Click="NextButton_Click" Width="70" Margin="5" FontSize="18"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
