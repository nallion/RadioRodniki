image: Visual Studio 2019

platform:
  - ARM

configuration:
  - Release

before_build:
  - nuget restore RodnikiRadio.sln
  - ps: |
      # 1. Создаем папку для ресурсов, если её нет
      if (!(Test-Path Assets)) { New-Item -ItemType Directory -Path Assets -Force }
      
      # 2. Генерация правильного самоподписанного сертификата для UWP
      Write-Host "Generating signing certificate..."
      $certSubject = "CN=AppVeyorSign"
      $certPassword = ConvertTo-SecureString "1234" -AsPlainText -Force
      
      $cert = New-SelfSignedCertificate -Type CodeSigningCert `
        -Subject $certSubject `
        -HashAlgorithm sha256 `
        -KeyLength 2048 `
        -CertStoreLocation "Cert:\CurrentUser\My" `
        -TextExtension @("2.5.29.37={text}1.3.6.1.5.5.7.3.3", "2.5.29.19={text}ca=0") 
      
      # 3. Экспорт в PFX файл
      Export-PfxCertificate -Cert $cert -FilePath "AppVeyorKey.pfx" -Password $certPassword
      Write-Host "Certificate AppVeyorKey.pfx created successfully."

build:
  project: RodnikiRadio.sln
  verbosity: minimal

after_build:
  # Собираем все артефакты: и сам пакет приложения, и сертификат (на случай, если он понадобится для ручной установки)
  - ps: Get-ChildItem -Recurse -Filter "*.appxbundle" | % { Push-AppveyorArtifact $_.FullName }
  - ps: if (Test-Path "AppVeyorKey.pfx") { Push-AppveyorArtifact "AppVeyorKey.pfx" }
