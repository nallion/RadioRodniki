<Page
    x:Class="RadioRodniki.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0d1117">

    <Page.Resources>
        <Style x:Key="RoundButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4fc3f7"/>
            <Setter Property="BorderBrush" Value="#4fc3f7"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="2"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Фон -->
        <Rectangle Fill="#0d1117"/>

        <!-- Градиентная полоска сверху -->
        <Rectangle Height="6" VerticalAlignment="Top">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1565c0" Offset="0"/>
                    <GradientStop Color="#0288d1" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="320" Spacing="0">

            <!-- Заголовок -->
            <Border Background="#141b24" BorderBrush="#1e2d3d" BorderThickness="1"
                    CornerRadius="4,4,0,0">
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1565c0" Offset="0"/>
                            <GradientStop Color="#0288d1" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Padding="20,16,20,14">
                        <TextBlock Text="РОДНИКИ"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="22"
                                   CharacterSpacing="300"
                                   Foreground="White"/>
                        <TextBlock Text="интернет-радио · прямой эфир"
                                   FontFamily="Segoe UI"
                                   FontStyle="Italic"
                                   FontSize="11"
                                   Foreground="#A0FFFFFF"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Статус -->
            <Border Background="#141b24" BorderBrush="#1e2d3d"
                    BorderThickness="1,0,1,0" Padding="20,12">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10"
                             Fill="#546e7a" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText"
                               Text="Нажмите ▶ для воспроизведения"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               Foreground="#cdd9e5"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Таймер переподключения -->
            <Border x:Name="ReconnectBanner" Background="#1A1e2d3d"
                    BorderBrush="#1e2d3d" BorderThickness="1,0,1,0"
                    Padding="20,6" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="⟳" Foreground="#4fc3f7" FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Переподключение…" Foreground="#4fc3f7"
                               FontSize="12" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ReconnectSecs" Foreground="White"
                               FontSize="18" FontFamily="Segoe UI"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="сек" Foreground="#546e7a" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Кнопки управления -->
            <Border Background="#141b24" BorderBrush="#1e2d3d"
                    BorderThickness="1,0,1,1" CornerRadius="0,0,4,4"
                    Padding="20,20,20,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Громкость -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center"
                                Margin="0,0,16,0" Spacing="6">
                        <TextBlock Text="ГРОМКОСТЬ" FontFamily="Segoe UI"
                                   FontSize="10" CharacterSpacing="200"
                                   Foreground="#546e7a"/>
                        <Slider x:Name="VolumeSlider"
                                Minimum="0" Maximum="100" Value="90"
                                Foreground="#4fc3f7"
                                ValueChanged="VolumeSlider_ValueChanged"/>
                    </StackPanel>

                    <!-- Кнопка Play/Stop -->
                    <Button x:Name="PlayButton" Grid.Column="1"
                            Style="{StaticResource RoundButtonStyle}"
                            Content="▶" Click="PlayButton_Click"/>
                </Grid>
            </Border>

            <!-- Footer -->
            <TextBlock Text="rodniki.hostingradio.ru  ·  AAC+"
                       FontFamily="Segoe UI" FontSize="10"
                       CharacterSpacing="150"
                       Foreground="#546e7a"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0"/>

        </StackPanel>
    </Grid>
</Page>
